                 <% if(theme.link.theme === 'white'){ %>
                     <i class="iconfont icon-<%= key %>"></i>
                 <% } else { %>
                     <svg class="iconfont-svg" aria-hidden="true">
                         <use xlink:href="#icon-<%= key %>"></use>
                     </svg>
                 <% } %>
             </a>
         <% } %>
     <% } %>
