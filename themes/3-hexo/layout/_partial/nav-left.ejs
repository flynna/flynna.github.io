             <a title="<%= key %>"
                href="<% if(key === 'qq') { %>http://wpa.qq.com/msgrd?v=3&uin=<%= theme.link.items[key] %>&site=qq&menu=yes<% }else{ if(key === 'email') { %>mailto:<% } %><%= theme.link.items[key] %><% } %>"
